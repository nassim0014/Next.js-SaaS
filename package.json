{
  "name": "nextjs-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Next.js 16 SaaS boilerplate — AI-native, multi-tenant, MCP-ready.",
  "license": "(MIT OR Commercial)",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "build": "next build",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "NODE_OPTIONS='--dns-result-order=ipv4first' dotenv -e .env.local -- prisma generate",
    "db:push": "NODE_OPTIONS='--dns-result-order=ipv4first' dotenv -e .env.local -- prisma db push",
    "db:migrate": "NODE_OPTIONS='--dns-result-order=ipv4first' dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "NODE_OPTIONS='--dns-result-order=ipv4first' dotenv -e .env.local -- prisma migrate deploy",
    "db:seed": "NODE_OPTIONS='--dns-result-order=ipv4first' dotenv -e .env.local -- tsx prisma/seed.ts",
    "setup": "bash scripts/setup.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/react": "^1.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.62.0",
    "ai": "^4.0.0",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq-sdk": "^0.7.0",
    "lucide-react": "^0.469.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
