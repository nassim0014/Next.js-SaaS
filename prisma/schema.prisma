// =============================================================================
// AI SaaS Boilerplate — Prisma Schema
// -----------------------------------------------------------------------------
// Provider:   PostgreSQL (Supabase)
// Multi-tenancy: shared DB, `organizationId` on every tenant-scoped table
// Auth: Supabase Auth (User.id mirrors auth.users.id via UUID)
// Vector: pgvector extension for RAG embeddings
//
// DESIGN PRINCIPLES
//   1. Every tenant table carries `organizationId` + a composite index on it
//   2. UUIDs everywhere (Supabase-friendly, no sequential ID enumeration attacks)
//   3. Soft references for high-volume tables (TokenUsage, AuditLog)
//   4. Money stored in cents (Int), never floats
//   5. Snake_case column names via @map for SQL ergonomics
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum RoleName {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  PAUSED
}

enum BillingEventType {
  INVOICE_PAID
  INVOICE_FAILED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  USAGE_RECORDED
  REFUND_ISSUED
}

enum AgentStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  INVITE
  ROLE_CHANGE
  API_KEY_USED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookEventStatus {
  PENDING
  DELIVERED
  FAILED
}

enum DataRequestType {
  EXPORT
  DELETION
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// =============================================================================
// IDENTITY & MULTI-TENANCY
// =============================================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  name          String?
  avatarUrl     String?   @map("avatar_url")
  locale        String    @default("en")
  emailVerified DateTime? @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  memberships   Membership[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  conversations Conversation[]
  tokenUsage    TokenUsage[]
  dataRequests  DataRequest[]

  @@map("users")
}

model Organization {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  logoUrl      String?   @map("logo_url")
  billingEmail String?   @map("billing_email")
  trialEndsAt  DateTime? @map("trial_ends_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  memberships      Membership[]
  invitations      Invitation[]
  agents           Agent[]
  conversations    Conversation[]
  knowledgeBases   KnowledgeBase[]
  subscriptions    Subscription[]
  billingEvents    BillingEvent[]
  usageRecords     UsageRecord[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  auditLogs        AuditLog[]
  dataRequests     DataRequest[]
  fileAssets       FileAsset[]

  @@index([slug])
  @@map("organizations")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  role           RoleName         @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@map("memberships")
}

model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  email          String
  organizationId String    @map("organization_id") @db.Uuid
  role           RoleName  @default(MEMBER)
  token          String    @unique @default(uuid())
  invitedById    String    @map("invited_by_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email, organizationId])
  @@map("invitations")
}

// =============================================================================
// RBAC
// =============================================================================

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  action      String // e.g. "conversations:read", "billing:manage"
  description String?
  roles       RolePermission[]

  @@unique([action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  role         RoleName

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// AI DOMAIN
// =============================================================================

model Agent {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  name           String
  description    String?
  systemPrompt   String?     @map("system_prompt") @db.Text
  modelConfigId  String?     @map("model_config_id") @db.Uuid
  status         AgentStatus @default(DRAFT)
  temperature    Float       @default(0.7)
  maxTokens      Int         @default(4096) @map("max_tokens")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modelConfig   ModelConfig?   @relation(fields: [modelConfigId], references: [id])
  conversations Conversation[]

  @@index([organizationId, status])
  @@map("agents")
}

model ModelConfig {
  id              String       @id @default(uuid()) @db.Uuid
  provider        String // "openai" | "anthropic" | "cohere" | "mistral"
  modelName       String       @map("model_name") // "gpt-4o" | "claude-3-5-sonnet" | etc.
  displayName     String       @map("display_name")
  contextWindow   Int          @map("context_window")
  inputCostPer1K  Float        @map("input_cost_per1_k") // USD per 1K input tokens
  outputCostPer1K Float        @map("output_cost_per1_k") // USD per 1K output tokens
  capabilities    Json?
  agents          Agent[]
  tokenUsage      TokenUsage[]
  messages        Message[]

  @@unique([provider, modelName])
  @@map("model_configs")
}

model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @map("organization_id") @db.Uuid
  agentId          String?            @map("agent_id") @db.Uuid
  userId           String?            @map("user_id") @db.Uuid
  title            String?
  status           ConversationStatus @default(ACTIVE)
  tokenCount       Int                @default(0) @map("token_count")
  estimatedCostUsd Float              @default(0) @map("estimated_cost_usd")
  metadata         Json?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  messages     Message[]

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String      @db.Text
  tokenCount     Int         @default(0) @map("token_count")
  modelConfigId  String?     @map("model_config_id") @db.Uuid
  toolCalls      Json?       @map("tool_calls")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  modelConfig  ModelConfig? @relation(fields: [modelConfigId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// =============================================================================
// RAG / KNOWLEDGE BASE  (pgvector)
// =============================================================================

model KnowledgeBase {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String?
  embeddingModel String   @default("text-embedding-3-small") @map("embedding_model")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([organizationId])
  @@map("knowledge_bases")
}

model Document {
  id              String         @id @default(uuid()) @db.Uuid
  knowledgeBaseId String         @map("knowledge_base_id") @db.Uuid
  fileAssetId     String?        @unique @map("file_asset_id") @db.Uuid
  title           String
  sourceUrl       String?        @map("source_url")
  status          DocumentStatus @default(PENDING)
  chunkCount      Int            @default(0) @map("chunk_count")
  charCount       Int            @default(0) @map("char_count")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  fileAsset     FileAsset?    @relation(fields: [fileAssetId], references: [id])
  embeddings    Embedding[]

  @@index([knowledgeBaseId, status])
  @@map("documents")
}

model Embedding {
  id         String                      @id @default(uuid()) @db.Uuid
  documentId String                      @map("document_id") @db.Uuid
  chunkIndex Int                         @map("chunk_index")
  content    String                      @db.Text
  embedding  Unsupported("vector(1536)")
  metadata   Json?
  createdAt  DateTime                    @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("embeddings")
}

// =============================================================================
// AI COST OBSERVABILITY  — ⭐ THE 5TH CREATIVE USP
// -----------------------------------------------------------------------------
// Every LLM call is metered and attributed to org + user + conversation + model.
// This powers: budget caps, usage-based billing, per-tenant cost dashboards,
// and overage protection. No AI SaaS boilerplate ships with this out of the box.
// =============================================================================

model TokenUsage {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  modelConfigId  String   @map("model_config_id") @db.Uuid
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  costUsd        Float    @map("cost_usd")
  cachedTokens   Int      @default(0) @map("cached_tokens")
  requestId      String?  @map("request_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user        User?       @relation(fields: [userId], references: [id])
  modelConfig ModelConfig @relation(fields: [modelConfigId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId])
  @@map("token_usage")
}

// =============================================================================
// BILLING
// =============================================================================

model Plan {
  id             String  @id @default(uuid()) @db.Uuid
  slug           String  @unique // "starter", "pro", "enterprise"
  name           String
  description    String?
  priceMonthly   Int     @map("price_monthly") // cents
  priceYearly    Int     @map("price_yearly") // cents
  tokenQuota     Int     @map("token_quota") // monthly token allowance, -1 for unlimited
  seatQuota      Int     @map("seat_quota")
  storageQuotaMb Int     @map("storage_quota_mb")
  features       Json?
  isActive       Boolean @default(true) @map("is_active")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(TRIALING)
  provider           String             @default("stripe") // "stripe" | "lemonsqueezy"
  providerCustomerId String?            @map("provider_customer_id")
  providerSubId      String?            @map("provider_sub_id")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  metadata           Json?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@unique([organizationId, provider])
  @@map("subscriptions")
}

model BillingEvent {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  type            BillingEventType
  amountCents     Int              @default(0) @map("amount_cents")
  currency        String           @default("usd")
  provider        String           @default("stripe")
  providerEventId String?          @unique @map("provider_event_id")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("billing_events")
}

model UsageRecord {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  metric         String // "tokens" | "storage_mb" | "seats"
  value          Int
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metric, periodStart])
  @@map("usage_records")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String?     @map("organization_id") @db.Uuid
  userId         String?     @map("user_id") @db.Uuid
  action         AuditAction
  resourceType   String      @map("resource_type")
  resourceId     String?     @map("resource_id")
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// API KEYS & WEBHOOKS
// =============================================================================

model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  name           String
  hashedKey      String       @unique @map("hashed_key") // argon2 hash of the actual key
  prefix         String // first 8 chars for display "nk_live_abcd..."
  lastUsedAt     DateTime?    @map("last_used_at")
  expiresAt      DateTime?    @map("expires_at")
  status         ApiKeyStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  revokedAt      DateTime?    @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
  @@map("api_keys")
}

model WebhookEndpoint {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  url            String
  events         String[] // ["conversation.created", "billing.invoice_paid"]
  secret         String // HMAC signing secret
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookEvent[]

  @@index([organizationId, isActive])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id           String             @id @default(uuid()) @db.Uuid
  endpointId   String             @map("endpoint_id") @db.Uuid
  eventType    String             @map("event_type")
  payload      Json
  status       WebhookEventStatus @default(PENDING)
  responseCode Int?               @map("response_code")
  attempts     Int                @default(0)
  nextRetryAt  DateTime?          @map("next_retry_at")
  deliveredAt  DateTime?          @map("delivered_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_events")
}

// =============================================================================
// GDPR / COMPLIANCE
// =============================================================================

model DataRequest {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  type              DataRequestType
  status            DataRequestStatus @default(PENDING)
  downloadUrl       String?           @map("download_url") // signed URL when ready (EXPORT)
  downloadExpiresAt DateTime?         @map("download_expires_at")
  requestedAt       DateTime          @default(now()) @map("requested_at")
  completedAt       DateTime?         @map("completed_at")
  metadata          Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
  @@index([userId, status])
  @@map("data_requests")
}

// =============================================================================
// STORAGE
// =============================================================================

model FileAsset {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  uploadedById   String?  @map("uploaded_by_id") @db.Uuid
  storagePath    String   @map("storage_path") // path inside Supabase Storage bucket
  bucket         String   @default("uploads")
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  checksum       String? // sha256
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document?

  @@index([organizationId, createdAt])
  @@map("file_assets")
}
